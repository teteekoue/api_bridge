<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Instructions flottantes en haut (non bloquantes) -->
    <LinearLayout
        android:id="@+id/calibration_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#BB000000"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/txt_calibration_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Déplacez la ZONE ROUGE sur l'élément\n2. CLIQUEZ DANS LA ZONE pour enregistrer"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_cancel_calibration"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginTop="5dp"
            android:padding="0dp"
            android:text="Annuler"
            android:textSize="12sp"
            android:backgroundTint="#FF4444" />
    </LinearLayout>

    <!-- La ZONE DE CALIBRAGE (Rectangle mobile) -->
    <FrameLayout
        android:id="@+id/calibration_zone"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:background="#44FF0000">

        <!-- Bordure visuelle -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:drawable/dialog_holo_light_frame"
            android:alpha="0.5" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="ZONE DE CLIC"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:textSize="12sp" />
            
        <!-- Poignée pour déplacer -->
        <ImageView
            android:id="@+id/zone_drag_handle"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="top|left"
            android:src="@android:drawable/ic_menu_move"
            android:background="#88000000" />
    </FrameLayout>

</FrameLayout>
