<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calibration_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#AA000000"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/txt_calibration_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLIQUEZ SUR : LA BARRE DE TEXTE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_calibration_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="MODE ACTUEL : ENREGISTREMENT"
            android:textColor="#FFEB3B"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_toggle_mode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MODE DÉFILEMENT"
                android:backgroundTint="#2196F3" />

            <View android:layout_width="10dp" android:layout_height="1px" />

            <Button
                android:id="@+id/btn_cancel_calibration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ANNULER"
                android:backgroundTint="#F44336" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/calibration_cursor"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_menu_myplaces"
        android:visibility="gone" />

</FrameLayout>
